# ── Server ────────────────────────────────────────────
FLASK_PORT=5000
FLASK_ENV=development      # 改成 production 上線後驗證碼不會回傳前端

# ── Security ─────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-string
ADMIN_PASSWORD=admin123

# ── Database ─────────────────────────────────────────
DB_PATH=scheduling.db      # SQLite 檔案路徑

# ── Email Domain Whitelist ────────────────────────────
# 允許登入的 Email @後網域，多個以逗號分隔
# 留空或不設定表示不限制任何網域
# 例：ALLOWED_EMAIL_DOMAINS=company.com,partner.org
ALLOWED_EMAIL_DOMAINS=

# ── LINE Login ────────────────────────────────────────────
# 至 https://developers.line.biz 建立 LINE Login Channel 後取得
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
# 必須與 LINE Developers Console 設定的 Callback URL 相同
LINE_REDIRECT_URI=https://your-app.onrender.com/api/auth/line/callback
